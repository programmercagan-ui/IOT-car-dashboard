/* ================= WEB SERVER KURULUMU ================= */
void setupWebServerRoutes() {
  server.on("/", [](){ server.send(200,"text/html",page()); });
  server.on("/mode", [](){ 
    currentMode = server.arg("m").toInt(); 
    EEPROM.write(EEPROM_ADDR_MODE, currentMode);
    EEPROM.commit();
    server.send(200,"text/html",page()); 
  });
  
  server.on("/set", [](){ 
    if(server.arg("s")!="") rpmStart = server.arg("s").toInt();
    if(server.arg("g")!="") rpmGreenEnd = server.arg("g").toInt();
    if(server.arg("y")!="") rpmYellowEnd = server.arg("y").toInt();
    if(server.arg("r")!="") rpmRedEnd = server.arg("r").toInt();
    
    if(server.hasArg("b")) { 
      ledBrightness = server.arg("b").toInt(); 
      FastLED.setBrightness(ledBrightness);
      EEPROM.write(EEPROM_ADDR_BRIGHTNESS, ledBrightness);
    }
    allowFakeRPM = server.hasArg("f"); 
    EEPROM.write(EEPROM_ADDR_FAKE, allowFakeRPM ? 1 : 0);

    EEPROM.put(EEPROM_ADDR_RPMSTART, rpmStart);
    EEPROM.put(EEPROM_ADDR_RPMGREEN, rpmGreenEnd);
    EEPROM.put(EEPROM_ADDR_RPMYELLOW, rpmYellowEnd);
    EEPROM.put(EEPROM_ADDR_RMPRED, rpmRedEnd);
    EEPROM.commit(); 
    server.send(200,"text/html",page());
  });
}

/* ================= LED EFEKT FONKSIYONLARI ================= */
void drawCenter(int p, CRGB c) {
  for (int i = 0; i < p; i++) {
    if (centerLeft - i >= 0) leds[centerLeft - i] = c;
    if (centerRight + i < NUM_LEDS) leds[centerRight + i] = c;
  }
}

void shiftStrobe() {
  if (millis() - lastStrobeTime >= strobeDelay) {
    lastStrobeTime = millis();
    strobeState = !strobeState;
    fill_solid(leds, NUM_LEDS, strobeState ? CRGB::Red : CRGB::White);
  } else {
     fill_solid(leds, NUM_LEDS, strobeState ? CRGB::Red : CRGB::White);
  }
}

void reverseShiftStrobe() {
  if (millis() - lastStrobeTime >= strobeDelay) {
    lastStrobeTime = millis();
    strobeState = !strobeState;
    fill_solid(leds, NUM_LEDS, CRGB::Blue); 
    if (strobeState) { leds[3] = CRGB::White; leds[4] = CRGB::White; }
  } else {
     fill_solid(leds, NUM_LEDS, CRGB::Blue); 
     if (strobeState) { leds[3] = CRGB::White; leds[4] = CRGB::White; }
  }
}

void aeroStrobe() {
  unsigned long m = millis() % 2000; 
  fill_solid(leds, NUM_LEDS, CRGB::Red);
  if ((m >= 0 && m < 40) || (m >= 140 && m < 180) || (m >= 280 && m < 320) || (m >= 420 && m < 460) || (m >= 660 && m < 910)) 
  { fill_solid(leds, NUM_LEDS, CRGB::White); }
}

void heartbeatEffect() {
  float bpm = 60.0; unsigned long ms = millis();
  float beat = pow(sin(PI * bpm * ms / 60000.0), 10); 
  float beat2 = pow(sin(PI * bpm * ms / 60000.0 + 0.3), 10);
  uint8_t brightness = constrain((beat + beat2) * 255, 0, 255);
  fadeToBlackBy(leds, NUM_LEDS, 20); 
  for(int i=0; i<NUM_LEDS/2; i++) {
    leds[centerLeft-i] = CRGB::Red; leds[centerRight+i] = CRGB::Red;
    leds[centerLeft-i].nscale8(brightness); leds[centerRight+i].nscale8(brightness);
  }
}

void cyberpunkGlitch() {
  if (random8() > 220) { leds[random8(NUM_LEDS)] = (random8() > 128) ? CRGB::DeepPink : CRGB::Cyan; }
  fadeToBlackBy(leds, NUM_LEDS, 50); 
}

void raindropEffect() {
  fadeToBlackBy(leds, NUM_LEDS, 40);
  if (random8() > 230) { leds[random8(NUM_LEDS)] = CRGB::Blue; }
}

void knightRider() {
  if (millis() - lastChaseTime > 80) {
    lastChaseTime = millis();
    fadeToBlackBy(leds, NUM_LEDS, 150); 
    leds[knightPos] = CRGB::Red;
    knightPos += knightDir;
    if (knightPos <= 0 || knightPos >= NUM_LEDS - 1) knightDir *= -1;
  }
}

void linearFill(int rpm) {
  FastLED.clear(); 
  if (rpm < rpmStart) return; 
  int numLedsToLight = map(constrain(rpm, rpmStart, rpmRedEnd), rpmStart, rpmRedEnd, 1, NUM_LEDS);
  for (int i = 0; i < numLedsToLight; i++) {
    int reversedIndex = (NUM_LEDS - 1) - i; 
    if (rpm < rpmGreenEnd) leds[reversedIndex] = CRGB::Green;
    else if (rpm < rpmYellowEnd) leds[reversedIndex] = CRGB::Yellow;
    else leds[reversedIndex] = CRGB::Red;
  }
  if (rpm >= rpmRedEnd) shiftStrobe();
}

void gunluk(int rpm) {
  FastLED.clear(); // Her karede temizle
  
  // 1. Durum: Devir başlangıcın altındaysa hiçbir şey yakma
  if (rpm < rpmStart) return;

  // 2. Durum: BAŞLANGIÇ - YEŞİL SON (Hazırlık Bölgesi)
  // Bu aralıkta sadece en ortadaki 2 LED yeşil yanar, beklemede kalır.
  if (rpm < rpmGreenEnd) {
    drawCenter(1, CRGB::Green); 
  }
  
  // 3. Durum: YEŞİL SON - SARI SON (Asıl Dolma Bölgesi)
  // Devir 2700'ü (GreenEnd) geçtiği an orta 2 LED sarıya döner 
  // ve 3200'e (YellowEnd) kadar sağa-sola tek tek dolarak 8 LED olur.
  else if (rpm < rpmYellowEnd) {
    // p=1 (orta 2) ile p=4 (8 LED) arası yağ gibi dolar
    int p = map(rpm, rpmGreenEnd, rpmYellowEnd, 1, 4);
    drawCenter(p, CRGB::Yellow);
  }
  
  // 4. Durum: SARI SON - KIRMIZI SON (Kritik Bölge)
  // 3200 devri geçtiğin an her yer aniden KIRMIZI olur.
  else if (rpm < rpmRedEnd) {
    fill_solid(leds, NUM_LEDS, CRGB::Red);
  }
  
  // 5. Durum: KIRMIZI SON VE ÜSTÜ (Yarış/Vites Bölgesi)
  // 3500 devri geçtiğin an çakarlar patlar.
  else {
    shiftStrobe();
  }
}

int getFakeRPM() {
  if (millis() - lastFakeTime > 20) { 
    lastFakeTime = millis();
    fakeRPM += (fakeDir * 50); 
    if (fakeRPM >= rpmRedEnd + 200) { fakeRPM = rpmRedEnd + 200; fakeDir = -1; }
    if (fakeRPM <= 800) { fakeRPM = 800; fakeDir = 1; }
  }
  return fakeRPM;
}
