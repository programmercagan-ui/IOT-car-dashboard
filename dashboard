uint8_t calcGear(float rpm, float speed){

  if (speed < 5) return 0;
  if (rpm < 1100) return 0;

  float ratio = rpm / speed;
  uint8_t currentGear = 0;

  // EGEA 1.3 DİZEL ORANLARI
  if      (ratio > 95) currentGear = 1;
  else if (ratio > 53) currentGear = 2;
  else if (ratio > 35) currentGear = 3;
  else if (ratio > 25) currentGear = 4;
  else                 currentGear = 5;

  static uint8_t lastCalculatedGear = 0;
  static uint8_t stableGear = 0;
  static int confirmCount = 0;

  if (currentGear == 0) {
      stableGear = 0;
      confirmCount = 0;
  }
  else if (currentGear > stableGear) {

      if (currentGear == lastCalculatedGear) {
          confirmCount++;
          if (confirmCount >= 1) {
              stableGear = currentGear;
              confirmCount = 0;
          }
      } else {
          confirmCount = 0;
      }
  }
  else {
      stableGear = currentGear;
      confirmCount = 0;
  }

  lastCalculatedGear = currentGear;
  return stableGear;
}

/* ================= OBD REQUEST ================= */
int getOBDData(WiFiClient &client, String cmd, String expectedPrefix, int byteCount) {
  while(client.available()) client.read(); 
  client.print(cmd + "\r");
  String resp = "";
  long timeout = millis() + 400; 
 while(millis() < timeout) {
  if(client.available()) {
    char c = client.read();
    if(c == '>') break;
    resp += c;
  } else {
    vTaskDelay(1);   // SADECE veri yokken uyur
  }
}
  resp.replace(" ", ""); resp.replace("\r", ""); resp.replace("\n", "");
  int idx = resp.indexOf(expectedPrefix);
  if (idx >= 0 && resp.length() >= idx + expectedPrefix.length() + (byteCount * 2)) {
    String hexData = resp.substring(idx + expectedPrefix.length(), idx + expectedPrefix.length() + (byteCount * 2));
    return strtol(hexData.c_str(), NULL, 16);
  }
  return -1; 
}

