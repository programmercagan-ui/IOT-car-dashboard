/* ================= OBD TASK (CORE 0) ================= */

/* ================= OBD TASK (CORE 0) ================= */
void obdTask(void *pv){
  WiFi.mode(WIFI_STA); 
  WiFi.setSleep(false);
  WiFi.begin(ssid, password);

  WiFiClient client;
  bool isOBDConnected = false;
  
  // 🔥 ZOMBİ BAĞLANTIYI AVLAMA SAYACI
  int errorCount = 0; 

  while(1) {
    xSemaphoreTake(dataMutex, portMAX_DELAY);
    car.wifiConnected = (WiFi.status() == WL_CONNECTED);
    xSemaphoreGive(dataMutex);

    if (WiFi.status() != WL_CONNECTED) {
      isOBDConnected = false;
      vTaskDelay(500 / portTICK_PERIOD_MS);
      continue;
    }

    if (!client.connected()) {
      isOBDConnected = false;
      xSemaphoreTake(dataMutex, portMAX_DELAY);
      car.obdConnected = false;
      xSemaphoreGive(dataMutex);

      if (client.connect(elmIP, elmPort)) {
        
        // 1. ICAR PRO UYANDIRMA
        client.print("\r");      
        vTaskDelay(1000 / portTICK_PERIOD_MS); 
        while (client.available()) client.read(); 

        // 2. WARM START
        client.print("ATWS\r");      
        vTaskDelay(1000 / portTICK_PERIOD_MS); 
        while (client.available()) client.read(); 

        // 3. TEMEL AYARLAR
        client.print("ATE0\r"); vTaskDelay(200 / portTICK_PERIOD_MS);
        client.print("ATSP0\r"); vTaskDelay(600 / portTICK_PERIOD_MS);
        client.print("ATAT1\r"); vTaskDelay(200 / portTICK_PERIOD_MS);
        client.print("ATH0\r"); vTaskDelay(200 / portTICK_PERIOD_MS);
        while (client.available()) client.read();

        // 4. ECU HANDSHAKE TEST
        int ready = -1;
        for(int i = 0; i < 5; i++) {
            ready = getOBDData(client, "0100", "4100", 4);
            if(ready >= 0) break;
            vTaskDelay(1000 / portTICK_PERIOD_MS);
        }

        if(ready < 0) {
            client.stop();
            isOBDConnected = false;
            xSemaphoreTake(dataMutex, portMAX_DELAY); car.obdConnected = false; xSemaphoreGive(dataMutex);
            vTaskDelay(1000 / portTICK_PERIOD_MS);
            continue; 
        } 
        
        // 5. BAŞARILI BAĞLANTI
        isOBDConnected = true;
        errorCount = 0;
        xSemaphoreTake(dataMutex, portMAX_DELAY);
        car.obdConnected = true;
        xSemaphoreGive(dataMutex);
      }
    }

    if (isOBDConnected && client.connected()) {
      
      static int lastDashMode = -1;
      static bool telInitDone = false;
      static int telInitStep = 0, telFastStep = 0, telSlowStep = 0, slowPollCounter = 0;
      static uint8_t pidStep = 0;
      static uint8_t boostSkip = 0;
      int value = -1;

      

      // Telemetri ekranına yeni geçildiyse sayacı sıfırla (İlk açılışta hepsini çekmek için)
      if (dashMode != lastDashMode) {
          if (dashMode == 3) { telInitDone = false; telInitStep = 0; }
          lastDashMode = dashMode;
      }

      // =========================================================
      // EKRAN 0: MİNİMAL (Sadece RPM ve HIZ - Fişek gibi)
      // =========================================================
      if (dashMode == 0) {
        if (pidStep % 2 == 0) {
            value = getOBDData(client,"010C","410C",2); 
            if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.rpm = value/4.0; xSemaphoreGive(dataMutex); }
        } else {
            value = getOBDData(client,"010D","410D",1); 
            if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.speed = value; car.gear = calcGear(car.rpm, car.speed); xSemaphoreGive(dataMutex); }
        }
        pidStep++; if(pidStep > 1) pidStep = 0;
      }
      
       // =========================================================
      // EKRAN 1 & 2: KLASİK VE RACE (Senin Hızlandırılmış Orijinal Sistemin)
      // =========================================================
      else if (dashMode == 1 || dashMode == 2) {
        switch(pidStep){
          case 0: // 🔥 HER ZAMAN RPM (Öncelik 1)
            value = getOBDData(client,"010C","410C",2);
            if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.rpm = value/4.0; if(car.rpm>car.maxRpm) car.maxRpm=car.rpm; xSemaphoreGive(dataMutex); } 
            break;
            
          case 1: // 🔥 HIZ VE VİTES HESAPLAMA
            value = getOBDData(client,"010D","410D",1);
            if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.speed = value; car.gear = calcGear(car.rpm, car.speed); if(car.speed>car.maxSpeed) car.maxSpeed=car.speed; xSemaphoreGive(dataMutex); } 
            break;
            
          case 2: // 🔥 TEKRAR RPM (Öncelik 2)
            value = getOBDData(client,"010C","410C",2);
            if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.rpm = value/4.0; if(car.rpm>car.maxRpm) car.maxRpm=car.rpm; xSemaphoreGive(dataMutex); } 
            break;
            
          case 3: // 🔥 BOOST SEYRELTME MANTIĞI (2 Döngüde 1 Kere)
            boostSkip++;
            if(boostSkip >= 2) {
              value = getOBDData(client,"010B","410B",1);
              if(value>=0){ float boost=(value-100.0)*0.01; if(boost<0) boost=0; xSemaphoreTake(dataMutex, portMAX_DELAY); car.boost = boost; if(boost>car.maxBoost) car.maxBoost=boost; xSemaphoreGive(dataMutex); } 
              boostSkip = 0; 
            } else {
              value = getOBDData(client,"010C","410C",2);
              if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.rpm = value/4.0; if(car.rpm>car.maxRpm) car.maxRpm=car.rpm; xSemaphoreGive(dataMutex); }
            }
            break;
        }
        pidStep++; if(pidStep > 3) pidStep = 0;
      }
      
      // =========================================================
      // EKRAN 3: AKILLI TELEMETRİ (10 Veri Çekimi)
      // =========================================================
      else if (dashMode == 3) {
        if (!telInitDone) {
           // İlk açılışta 10 veriyi hızlıca 1 kere çek
           switch(telInitStep) {
             case 0: value = getOBDData(client,"0104","4104",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.engineLoad = value*100/255; xSemaphoreGive(dataMutex); } break;
             case 1: value = getOBDData(client,"0111","4111",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.throttlePos = value*100/255; xSemaphoreGive(dataMutex); } break;
             case 2: value = getOBDData(client,"0110","4110",2); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.maf = value/100.0; xSemaphoreGive(dataMutex); } break;
             case 3: value = getOBDData(client,"0142","4142",2); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.voltage = value/1000.0; xSemaphoreGive(dataMutex); } break;
             case 4: value = getOBDData(client,"0105","4105",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.coolantTemp = value-40; xSemaphoreGive(dataMutex); } break;
             case 5: value = getOBDData(client,"010F","410F",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.intakeTemp = value-40; xSemaphoreGive(dataMutex); } break;
             case 6: value = getOBDData(client,"0146","4146",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.ambientTemp = value-40; xSemaphoreGive(dataMutex); } break;
             case 7: value = getOBDData(client,"012F","412F",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.fuelLevel = value*100/255; xSemaphoreGive(dataMutex); } break;
             case 8:value = getOBDData(client,"2214A3","6214A3",1);if(value>=0){xSemaphoreTake(dataMutex, portMAX_DELAY);car.dpfLoad = map(value,0,255,0,100);xSemaphoreGive(dataMutex);}break;
             case 9: value = getOBDData(client,"011F","411F",2); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.runTime = value; xSemaphoreGive(dataMutex); } break;
           }
           telInitStep++;
           if(telInitStep > 9) telInitDone = true; 
        } 
        else {
           // Normal Çalışma: Hızlı verileri sürekli, yavaş verileri 10 turda 1 çek
           if (slowPollCounter >= 10) {
              switch(telSlowStep) {
                 case 0: value = getOBDData(client,"0105","4105",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.coolantTemp = value-40; xSemaphoreGive(dataMutex); } break;
                 case 1: value = getOBDData(client,"010F","410F",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.intakeTemp = value-40; xSemaphoreGive(dataMutex); } break;
                 case 2: value = getOBDData(client,"0146","4146",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.ambientTemp = value-40; xSemaphoreGive(dataMutex); } break;
                 case 3: value = getOBDData(client,"012F","412F",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.fuelLevel = value*100/255; xSemaphoreGive(dataMutex); } break;
                case 4:value = getOBDData(client,"2214A3","6214A3",1);if(value>=0){  xSemaphoreTake(dataMutex, portMAX_DELAY);car.dpfLoad = map(value,0,255,0,100);xSemaphoreGive(dataMutex);}break;
                 case 5: value = getOBDData(client,"011F","411F",2); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.runTime = value; xSemaphoreGive(dataMutex); } break;
              }
              telSlowStep++; if(telSlowStep > 5) telSlowStep = 0; 
              slowPollCounter = 0; 
           } 
           else {
              switch(telFastStep) {
                 case 0: value = getOBDData(client,"0104","4104",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.engineLoad = value*100/255; xSemaphoreGive(dataMutex); } break;
                 case 1: value = getOBDData(client,"0111","4111",1); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.throttlePos = value*100/255; xSemaphoreGive(dataMutex); } break;
                 case 2: value = getOBDData(client,"0110","4110",2); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.maf = value/100.0; xSemaphoreGive(dataMutex); } break;
                 case 3: value = getOBDData(client,"0142","4142",2); if(value>=0){ xSemaphoreTake(dataMutex, portMAX_DELAY); car.voltage = value/1000.0; xSemaphoreGive(dataMutex); } break;
              }
              telFastStep++;
              if(telFastStep > 3) { telFastStep = 0; slowPollCounter++; }
           }
        }
        vTaskDelay(50 / portTICK_PERIOD_MS); // Telemetride ECU'yu biraz daha rahat bırak
      }

      // 🔥 HATA KONTROLÜ (Zombi Bağlantı Tespiti)
      if (value >= 0) {
        errorCount = 0; 
      } else {
        errorCount++;  
      }

      // 🚨 Arka arkaya 30 kez veri alamazsak bağlantıyı kopar
      if (errorCount > 30) {
         client.stop(); 
         isOBDConnected = false;
         errorCount = 0;
         
         xSemaphoreTake(dataMutex, portMAX_DELAY);
         car.obdConnected = false;
         car.rpm = 0;   
         car.speed = 0;
         xSemaphoreGive(dataMutex);
         
         vTaskDelay(1000 / portTICK_PERIOD_MS); 
         continue; 
      }

    }
    
    vTaskDelay(25 / portTICK_PERIOD_MS); // Daha hızlı sorgu
  }
}

/* ================= UI TASK (CORE 1) - TUŞLA GEÇİŞ SİSTEMİ ================= */
void uiTask(void *pv){
  while(1){
    // 1. Tuş Kontrolü (4 Ekrana Göre Ayarlandı)
     if(millis() - lastButtonCheck > 30){

    lastButtonCheck = millis();

    bool buttonState = digitalRead(BUTTON_PIN) == LOW;

    if(buttonState && !buttonHolding){
        buttonHolding = true;
        buttonPressStart = millis();
    }

    if(!buttonState && buttonHolding){

        unsigned long pressTime = millis() - buttonPressStart;

        // 🔴 UZUN BASMA
        if(pressTime > 5000){

            if(ledBrightness > 50)
                ledBrightness = 20;
            else
                ledBrightness = 220;

            FastLED.setBrightness(ledBrightness);

            EEPROM.write(EEPROM_ADDR_BRIGHTNESS, ledBrightness);
            EEPROM.commit();
        }

        // 🔵 KISA BASMA
        else{
            clickCount++;
            lastClickTime = millis();
            waitForDouble = true;
        }

        buttonHolding = false;
    }

    // DOUBLE CLICK KONTROL
    if(waitForDouble && millis() - lastClickTime > 300){

        if(clickCount == 1){
            dashMode++;
            if(dashMode > 3) dashMode = 0;
        }

        if(clickCount == 2){
            currentMode++;
            if(currentMode > MODE_AERO) currentMode = 0;
        }

        clickCount = 0;
        waitForDouble = false;
    }
}

    // Veriyi kilitle ve kopyala
    CarData copy;
    xSemaphoreTake(dataMutex, portMAX_DELAY);
    copy = car;
    copy.rpm = displayRpm;
    xSemaphoreGive(dataMutex);

    // 2. Hangi Moddaysak O Ekranı Çiz
    if(dashMode == 0)      drawDashboardMinimal(copy);
    else if(dashMode == 1) drawDashboardClassic(copy);
    else if(dashMode == 2) drawDashboardRace(copy);
    else if(dashMode == 3) drawDashboardTelemetry(copy);
    
    vTaskDelay(16 / portTICK_PERIOD_MS); 
  }
}
/* ================= SETUP ================= */
void setup(){
  Serial.begin(115200);

  pinMode(BUTTON_PIN, INPUT_PULLUP);
  // Ekran Kurulumu
  tft.init(); tft.setRotation(1); sprite.createSprite(320, 240);

  // EEPROM Kurulumu
  EEPROM.begin(EEPROM_SIZE);
  EEPROM.get(EEPROM_ADDR_RPMSTART, rpmStart);
  EEPROM.get(EEPROM_ADDR_RPMGREEN, rpmGreenEnd);
  EEPROM.get(EEPROM_ADDR_RPMYELLOW, rpmYellowEnd);
  EEPROM.get(EEPROM_ADDR_RMPRED, rpmRedEnd);

  if(rpmStart <= 0 || rpmStart > 10000) rpmStart = 2200;
  if(rpmGreenEnd <= 0) rpmGreenEnd = 3000;
  if(rpmYellowEnd <= 0) rpmYellowEnd = 3300;
  if(rpmRedEnd <= 0) rpmRedEnd = 4000;

  currentMode = EEPROM.read(EEPROM_ADDR_MODE);
  ledBrightness = EEPROM.read(EEPROM_ADDR_BRIGHTNESS);
  if(ledBrightness < 5) ledBrightness = 220; 
  allowFakeRPM = (EEPROM.read(EEPROM_ADDR_FAKE) == 1);

  // LED Kurulumu
  FastLED.addLeds<LED_TYPE, LED_PIN, COLOR_ORDER>(leds, NUM_LEDS);
  FastLED.setBrightness(ledBrightness);
// 🔥 F1 STYLE START SEQUENCE

