/* ================= LOOP (WEB & LED YÖNETİMİ) ================= */
void loop() {
  
  if (!apModeStarted && millis() > 20000) {

  bool wifiOk = false;
  bool obdOk  = false;

  xSemaphoreTake(dataMutex, portMAX_DELAY);
  wifiOk = car.wifiConnected;
  obdOk  = car.obdConnected;
  xSemaphoreGive(dataMutex);

  // 🔥 Sadece WiFi hiç bağlanamadıysa AP aç
  if (!wifiOk) {

    WiFi.disconnect(true);
    delay(100);
    WiFi.mode(WIFI_AP);

    WiFi.softAP("EGEA_SHIFT_LIGHT", "12345678");

    setupWebServerRoutes();
    server.begin();

    apModeStarted = true;
  }
}

  // Web Server açıksa istekleri dinle
  if (apModeStarted) { server.handleClient(); }

  // 🏎️ LED Güncellemesi
  static unsigned long lastLedUpdate = 0;
  if (millis() - lastLedUpdate > 10) { // 100 FPS (Titremeyi önler)
      lastLedUpdate = millis();

      // RPM Verisini Güvenli Şekilde Çek
      float currentRpm = 0;
      xSemaphoreTake(dataMutex, portMAX_DELAY);
      currentRpm = car.rpm;
      xSemaphoreGive(dataMutex);

      if(allowFakeRPM) currentRpm = getFakeRPM();

     // 🔥 Ultra Minimal Smart Interpolation
     // 🔥 OBD durumunu kontrol et
bool obdOk = false;
xSemaphoreTake(dataMutex, portMAX_DELAY);
obdOk = car.obdConnected;
xSemaphoreGive(dataMutex);

if(!obdOk && !allowFakeRPM) {

    // OBD yok ve fake kapalı → RPM sabit 0
    displayRpm = 0;

} else {

    float diff = currentRpm - displayRpm;

    // Büyük fark → direkt atla
    if (abs(diff) > 400) {
        displayRpm = currentRpm;
    }
    else {
        displayRpm += diff * 0.25;
    }

    // Mikro canlılık sadece gerçek bağlantı varsa
    if (obdOk && currentRpm < 1200 && abs(diff) < 50) {
        displayRpm += sin(millis() * 0.008) * 1.5;
    }
}

displayRpm = constrain(displayRpm, 0, 7500);

int rpmToUse = (int)displayRpm;


      switch (currentMode) {
        case MODE_AERO:   aeroStrobe(); break;
        case MODE_KNIGHT: knightRider(); break;
        case MODE_DEMO:   fill_rainbow(leds, NUM_LEDS, hue++, 18); break;
        case MODE_HEART:  heartbeatEffect(); break;
        case MODE_GLITCH: cyberpunkGlitch(); break;
        case MODE_RAIN:   raindropEffect(); break;
        case MODE_GUNLUK: gunluk(rpmToUse); break;
        case MODE_LINEAR: linearFill((int)currentRpm); break;
        case MODE_REVERSE: 
             if (currentRpm >= rpmRedEnd) { reverseShiftStrobe(); } 
             else {
                 FastLED.clear();
                 if (currentRpm >= rpmStart) {
                     int lvl = map(constrain((int)currentRpm, rpmStart, rpmRedEnd), rpmStart, rpmRedEnd, 1, 4);
                     for (int i=0; i<lvl; i++) { leds[i] = CRGB::Blue; leds[NUM_LEDS-1-i] = CRGB::Blue; }
                 }
             } break;
        case MODE_CADDE:  
             if (currentRpm < rpmStart) {
                 if (millis() - lastChaseTime > 130) {
                     lastChaseTime = millis(); fadeToBlackBy(leds, NUM_LEDS, 120);
                     leds[chaseIndex] = CHSV(hue++, 255, 255); chaseIndex = (chaseIndex + 1) % NUM_LEDS;
                 }
             } else { gunluk((int)currentRpm); } break;
        case MODE_SPORT: 
             FastLED.clear();
             if (currentRpm >= rpmRedEnd) { shiftStrobe(); }
             else if (currentRpm >= rpmStart) {
                 int sideLeds = map(constrain((int)currentRpm, rpmStart, rpmRedEnd), rpmStart, rpmRedEnd, 1, 4);
                 for (int i = 0; i < sideLeds; i++) {
                     CRGB color = (currentRpm < rpmGreenEnd) ? CRGB::Green : (currentRpm < rpmYellowEnd ? CRGB::Yellow : CRGB::Red);
                     leds[i] = color; leds[NUM_LEDS - 1 - i] = color;
                 }
             } break;
      }
      FastLED.show();
  }
}

